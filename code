void handleData() {
  String jsonData = "{";
  jsonData += "\"methane\": " + String(methanePPM) + ",";
  jsonData += "\"ammonia\": " + String(ammoniaPPM) + ",";
  jsonData += "\"status\": \"" + safetyStatus + "\",";
  jsonData += "\"isDangerous\": " + String(isDangerous ? "true" : "false");
  jsonData += "}";

  server.send(200, "application/json", jsonData);
}
