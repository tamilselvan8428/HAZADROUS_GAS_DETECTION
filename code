#include <WiFi.h>
#include <WebServer.h>
#include <HTTPClient.h>

// WiFi Settings
const char* ssid = "OPPO A17k";
const char* password = "123456789";
const unsigned long wifiTimeoutMs = 15000; // 15 seconds connection timeout

// ThingSpeak Configuration
const char* thingSpeakWriteKey = "4EI9Q0S41ARSD9Q5";
const char* thingSpeakUrl = "http://api.thingspeak.com/update";
const unsigned long thingSpeakInterval = 15000; // 15 seconds rate limit

// Pin Definitions
const int mq6Pin = 34;    // MQ-6 Sensor pin
const int mq135Pin = 35;  // MQ-135 Sensor pin
const int ledPin = 32;    // Define the LED pin

WebServer server(80);

// Timing and State
unsigned long previousMillis = 0;
unsigned long lastThingSpeakMillis = 0;
const long interval = 1000; // Read sensors every 1 second

// Global Sensor Values
float methanePPM = 0.0;
float ammoniaPPM = 0.0;
bool isDangerous = false;
String safetyStatus = "Initializing...";

// Calibration Parameters
const float methane_slope = 4;  
const float methane_intercept = 10;
const float ammonia_slope = 0.01;   
const float ammonia_intercept = 10; 

float analogToPPM(int rawValue, float slope, float intercept) {
  return slope * rawValue + intercept;
}

void setup() {
  Serial.begin(115200);
  delay(100);

  // Set pin modes
  pinMode(mq6Pin, INPUT);
  pinMode(mq135Pin, INPUT);
  pinMode(ledPin, OUTPUT);
  digitalWrite(ledPin, LOW); // Start with LED off

  // Start connecting to WiFi (non-blocking style initialization)
  Serial.print("Connecting to ");
  Serial.println(ssid);
  WiFi.begin(ssid, password);

  unsigned long startAttemptTime = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - startAttemptTime < wifiTimeoutMs) {
    delay(500);
    Serial.print(".");
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println();
    Serial.println("WiFi connected.");
    Serial.print("IP address: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println();
    Serial.println("WiFi connection timed out. Starting system in standalone/offline mode.");
  }

  // Set up local server routing
  server.on("/", handleRoot);
  server.on("/data", handleData);

  server.begin();
  Serial.println("HTTP server started.");
}

void loop() {
  server.handleClient();

  unsigned long currentMillis = millis();

  // Periodically read sensor and perform safety actions locally (Every 1 second)
  if (currentMillis - previousMillis >= interval) {
    previousMillis = currentMillis;
 
    int methaneRaw = analogRead(mq6Pin);
    int ammoniaRaw = analogRead(mq135Pin);
    
    methanePPM = analogToPPM(methaneRaw, methane_slope, methane_intercept);
    ammoniaPPM = analogToPPM(ammoniaRaw, ammonia_slope, ammonia_intercept);

    isDangerous = (methanePPM > 1000) || (ammoniaPPM > 300);
    safetyStatus = isDangerous ? "Danger: High gas levels detected!" : "Gas levels are normal.";
    
    if (isDangerous) {
      digitalWrite(ledPin, HIGH);
    } else {
      digitalWrite(ledPin, LOW);
    }
  }

  // Periodically upload data to ThingSpeak (Every 15 seconds)
  if (currentMillis - lastThingSpeakMillis >= thingSpeakInterval) {
    lastThingSpeakMillis = currentMillis;

    if (WiFi.status() == WL_CONNECTED) {
      HTTPClient http;
      String url = String(thingSpeakUrl) + "?api_key=" + String(thingSpeakWriteKey) +
                   "&field1=" + String(methanePPM) +
                   "&field2=" + String(ammoniaPPM) +
                   "&field3=" + String(isDangerous ? 1 : 0);
      
      http.begin(url);
      int httpResponseCode = http.GET();
      
      if (httpResponseCode > 0) {
        Serial.print("ThingSpeak Update Successful. HTTP Response code: ");
        Serial.println(httpResponseCode);
      } else {
        Serial.print("Error on sending GET request to ThingSpeak: ");
        Serial.println(httpResponseCode);
      }
      http.end();
    } else {
      Serial.println("WiFi offline. Skipping ThingSpeak upload.");
    }
  }
}

